<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Las Tartas de Tania{% endblock %}</title>

    {# Bootstrap 5 #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    {# Bootstrap Icons (Para el carrito) #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    {% block stylesheets %}
        <style>
            body { background: #fff8f5; color: #3d2f2a; }
            .navbar-brand { font-size: 1.5rem; }
            main {
                background: #ffffff;
                padding: 2rem;
                border-radius: 12px;
                box-shadow: 0 4px 15px rgba(0,0,0,.05);
                margin-top: 2rem;
                min-height: 70vh;
            }
            .btn-primary-tania { background: #b35d7f; color: white; border: none; }
            .btn-primary-tania:hover { background: #964a68; color: white; }
            .bg-tania-soft { background-color: #f8d7da !important; }
            .nav-link:hover { color: #b35d7f !important; text-decoration: underline; }
            .active-tania { color: #b35d7f !important; font-weight: bold; }
            /* Estilo para el contador del carrito */
            .badge-cart { font-size: 0.65rem; padding: 0.35em 0.5em; }
        </style>
    {% endblock %}
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-light bg-tania-soft border-bottom shadow-sm">
    <div class="container">
        <a class="navbar-brand fw-bold text-danger" href="{{ path('app_home') }}">🍰 Las Tartas de Tania</a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarMain">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item"><a class="nav-link" href="{{ path('app_home') }}">Inicio</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('app_category_index') }}">Categorías</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('app_product_index') }}">Productos</a></li>
                {% if is_granted('ROLE_ADMIN') %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_pickup_appointment_index') }}">Citas</a>
                    </li>
                {% endif %}
            </ul>

            <div class="d-flex align-items-center gap-2">
                {# BOTÓN DEL CARRITO DENTRO DEL NAV #}
                <a href="{{ path('app_cart_index') }}" class="btn btn-outline-danger position-relative me-3 shadow-sm bg-white">
                    <i class="bi bi-cart3"></i> Mi Carrito
                    {% set cartCount = app.session.get('cart')|length %}
                    {% if cartCount > 0 %}
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger shadow badge-cart">
                            {{ cartCount }}
                        </span>
                    {% endif %}
                </a>

                {% if app.user %}
                    <div class="dropdown">
                        <button class="btn btn-light btn-sm dropdown-toggle fw-medium border shadow-sm" type="button" data-bs-toggle="dropdown">
                            👤 {{ app.user.userIdentifier }}
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                            <li><span class="dropdown-item-text text-muted small">Rol: {{ app.user.roles[0] }}</span></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger" href="{{ path('app_logout') }}">Cerrar Sesión</a></li>
                        </ul>
                    </div>
                {% else %}
                    <a class="btn btn-outline-dark btn-sm px-3" href="{{ path('app_login') }}">Entrar</a>
                    <a class="btn btn-danger btn-sm px-3 shadow-sm" href="{{ path('app_register') }}">Crear Cuenta</a>
                {% endif %}
            </div>
        </div>
    </div>
</nav>

<main class="container mb-5">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'error' ? 'danger' : (label == 'success' ? 'success' : 'info') }} alert-dismissible fade show shadow-sm" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}

    {% block body %}{% endblock %}
</main>

<footer class="text-center text-muted py-4 small mt-auto">
    <div class="container border-top pt-3">
        &copy; {{ "now"|date("Y") }} Las Tartas de Tania - Pastelería Artesanal <br>
        <span class="text-secondary small">Hecho por José María Bellido</span>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
{% block javascripts %}{% endblock %}

</body>
</html>
