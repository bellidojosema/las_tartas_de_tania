<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Las Tartas de Tania{% endblock %}</title>

    {# Bootstrap 5 #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">

    {% block stylesheets %}
        <style>
            body { background: #fff8f5; color: #3d2f2a; }
            .navbar-brand { font-size: 1.5rem; }
            main {
                background: #ffffff;
                padding: 2rem;
                border-radius: 12px;
                box-shadow: 0 4px 15px rgba(0,0,0,.05);
                margin-top: 2rem;
            }
            /* Colores personalizados de la marca */
            .btn-primary-tania { background: #b35d7f; color: white; border: none; }
            .btn-primary-tania:hover { background: #964a68; color: white; }
            .bg-tania-soft { background-color: #f8d7da !important; }
            .nav-link:hover { color: #b35d7f !important; text-decoration: underline; }
        </style>
    {% endblock %}
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-light bg-tania-soft border-bottom">
    <div class="container">
        <a class="navbar-brand fw-bold text-danger" href="{{ path('app_home') }}">🍰 Las Tartas de Tania</a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarMain">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item"><a class="nav-link" href="{{ path('app_home') }}">Inicio</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('app_product_index') }}">Productos</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('app_pickup_appointment_index') }}">Quedadas</a></li>

            </ul>

            <div class="d-flex align-items-center gap-3">
                {% if app.user %}
                    <span class="navbar-text fw-medium text-dark">Hola, {{ app.user.userIdentifier }}</span>
                    <a class="btn btn-outline-secondary btn-sm" href="{{ path('app_logout') }}">Cerrar Sesión</a>
                {% else %}
                    <a class="btn btn-outline-dark btn-sm" href="{{ path('app_login') }}">Entrar</a>
                    <a class="btn btn-danger btn-sm" href="{{ path('app_register') }}">Crear Cuenta</a>
                {% endif %}
            </div>
        </div>
    </div>
</nav>

<main class="container">
    {# Mensajes Flash de Symfony #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'error' ? 'danger' : (label == 'success' ? 'success' : 'info') }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}

    {% block body %}{% endblock %}
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
{% block javascripts %}{% endblock %}

</body>
</html>
