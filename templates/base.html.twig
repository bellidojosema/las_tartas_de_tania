<!DOCTYPE html>
<html lang="es">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Las Tartas de Tania{% endblock %}</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
        {% block stylesheets %}{% endblock %}
    </head>
    <body class="bg-light">
        <nav class="navbar navbar-expand-lg navbar-dark bg-danger-subtle border-bottom border-danger-subtle">
            <div class="container">
                <a class="navbar-brand fw-bold text-danger" href="{{ path('app_home') }}">🍰 Las Tartas de Tania</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain" aria-controls="navbarMain" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item"><a class="nav-link text-dark" href="{{ path('app_home') }}">Inicio</a></li>
                        <li class="nav-item"><a class="nav-link text-dark" href="{{ path('app_product_index') }}">Productos</a></li>
                    </ul>
                    <div class="d-flex gap-2">
                        {% if app.user %}
                            <span class="navbar-text text-dark me-2">Hola, {{ app.user.userIdentifier }}</span>
                            <a class="btn btn-outline-dark btn-sm" href="{{ path('app_logout') }}">Salir</a>
                        {% else %}
                            <a class="btn btn-outline-dark btn-sm" href="{{ path('app_login') }}">Login</a>
                            <a class="btn btn-danger btn-sm" href="{{ path('app_register') }}">Registrarte</a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </nav>

        <main class="container my-4">
            {% for message in app.flashes('success') %}
                <div class="alert alert-success">{{ message }}</div>
            {% endfor %}
            {% for message in app.flashes('error') %}
                <div class="alert alert-danger">{{ message }}</div>
            {% endfor %}

            {% block body %}{% endblock %}
        </main>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    </body>
</html>
