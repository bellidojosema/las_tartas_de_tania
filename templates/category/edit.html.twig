{% extends 'base.html.twig' %}

{% block title %}Editar Categoría - Las Tartas de Tania{% endblock %}

{% block body %}
    <div class="container mt-4">
        <div class="row justify-content-center">
            <div class="col-md-8">
                {# Cabecera con Botón de Borrar alineado #}
                <div class="d-flex justify-content-between align-items-end mb-4">
                    <div>
                        <h1 class="display-5 text-danger fw-bold mb-0">Editar Categoría</h1>
                        <p class="text-muted fs-5">Modifica los detalles de la familia de productos</p>
                    </div>

                </div>

                <div class="card shadow-sm border-0">
                    <div class="card-body p-4">
                        <h5 class="card-title fw-bold mb-4 text-dark">Información de la categoría</h5>

                        {# Reutilizamos el formulario con el label en español #}
                        {{ include('category/_form.html.twig', {'button_label': 'Actualizar'}) }}

                        <hr class="my-4 text-muted opacity-25">

                        <div class="d-flex justify-content-start">
                            <a href="{{ path('app_category_index') }}" class="btn btn-outline-secondary btn-sm px-3 shadow-sm">
                                <i class="bi bi-arrow-left me-1"></i> Cancelar y volver
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
