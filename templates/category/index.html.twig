{% extends 'base.html.twig' %}

{% block title %}Gestión de Categorías - Las Tartas de Tania{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h2 text-danger fw-bold mb-0">Categorías</h1>
            <p class="text-muted">Organiza tus productos por tipo de repostería</p>
        </div>
        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('app_category_new') }}" class="btn btn-danger btn-sm px-4 shadow-sm">
                + Nueva Categoría
            </a>
        {% endif %}
    </div>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                <tr>
                    <th class="ps-4">ID</th>
                    <th>Nombre de la Categoría</th>
                    <th class="text-center">Nº de Productos</th>
                    <th class="text-center pe-4">Acciones</th>
                </tr>
                </thead>
                <tbody>
                {% for category in categories %}
                    <tr>
                        <td class="ps-4 text-muted">#{{ category.id }}</td>
                        <td><strong class="text-dark">{{ category.name }}</strong></td>
                        <td class="text-center">
                            <span class="badge rounded-pill bg-light text-dark border">
                                {{ category.products|length }} productos
                            </span>
                        </td>
                        <td class="text-center pe-4">
                            <div class="btn-group" role="group">
                                <a href="{{ path('app_category_show', {'id': category.id}) }}" class="btn btn-outline-secondary btn-sm">Ver</a>
                                {% if is_granted('ROLE_ADMIN') %}
                                    <a href="{{ path('app_category_edit', {'id': category.id}) }}" class="btn btn-warning btn-sm">Editar</a>
                                    {{ include('category/_delete_form.html.twig') }}
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
