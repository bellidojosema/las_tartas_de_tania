{% extends 'base.html.twig' %}

{% block title %}Finalizar Compra - Las Tartas de Tania{% endblock %}

{% block body %}
    <div class="container py-5">
        <h1 class="h2 text-danger fw-bold mb-4">Confirmar Pedido</h1>

        <div class="row g-5">
            <div class="col-md-7">
                <div class="card shadow-sm border-0 p-4">
                    <h4 class="mb-3">Información de Recogida</h4>
                    {{ form_start(form) }}
                    {{ form_widget(form) }}
                    <button class="btn btn-danger btn-lg w-100 mt-4 shadow-sm">
                        Confirmar y Realizar Pedido
                    </button>
                    {{ form_end(form) }}
                </div>
            </div>

            <div class="col-md-5">
                <div class="p-4 bg-tania-soft rounded-3 shadow-sm">
                    <h4 class="text-danger">Resumen Ético</h4>
                    <p class="small text-muted">Recuerda que Tania prepara las tartas bajo pedido artesanalmente.</p>
                    <hr>
                    <div class="d-flex justify-content-between">
                        <span>Estado:</span>
                        <span class="badge bg-warning text-dark">Pendiente de Pago</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
