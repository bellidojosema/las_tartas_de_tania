{% extends 'base.html.twig' %}

{% block title %}Las Tartas de Tania - Pastelería Artesanal{% endblock %}

{% block body %}
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-danger">Nuestras Tartas Artesanales</h1>
        <p class="lead text-muted">Hechas con amor, directamente del horno de Tania</p>
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        {% for product in products %}
            <div class="col">
                <div class="card h-100 shadow-sm border-0 overflow-hidden" style="border-radius: 15px;">
                    {# Espacio para una imagen futura #}
                    <div class="bg-tania-soft d-flex align-items-center justify-content-center" style="height: 200px;">
                        <span style="font-size: 4rem;">🍰</span>
                    </div>

                    <div class="card-body text-center">
                    <span class="badge rounded-pill bg-light text-danger border mb-2">
                        {{ product.category.name }}
                    </span>
                        <h5 class="card-title fw-bold text-dark">{{ product.name }}</h5>
                        <p class="card-text h4 text-success fw-bold">{{ product.price|number_format(2, ',', '.') }}€</p>
                    </div>

                    <div class="card-footer bg-white border-0 pb-4 text-center">
                        {# Hemos cambiado el '#' por la ruta real de añadir al carrito #}
                        <a href="{{ path('app_cart_add', {'id': product.id}) }}" class="btn btn-danger px-4 shadow-sm" style="border-radius: 20px;">
                            Añadir al carrito
                        </a>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12 text-center py-5">
                <p class="text-muted">Todavía no hay tartas en el catálogo. ¡Tania está cocinando!</p>
            </div>
        {% endfor %}
    </div>
{% endblock %}
