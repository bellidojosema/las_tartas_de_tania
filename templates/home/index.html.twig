{% extends 'base.html.twig' %}

{% block title %}Inicio | Las Tartas de Tania{% endblock %}

{% block body %}
    {# Sección Hero: Banner principal #}
    <section class="p-4 p-md-5 mb-4 bg-white rounded-3 shadow-sm border">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1 class="display-6 fw-bold text-danger">Las Tartas de Tania</h1>
                <p class="lead mb-4">Gestión online de tartas y galletas caseras: catálogo, quedadas y recetas.</p>
                <div class="d-flex flex-wrap gap-2">
                    {% if not app.user %}
                        <a class="btn btn-danger px-4" href="{{ path('app_login') }}">Iniciar sesión</a>
                        <a class="btn btn-outline-danger px-4" href="{{ path('app_register') }}">Registrarte</a>
                    {% endif %}
                    <a class="btn btn-dark px-4" href="{{ path('app_product_index') }}">Ver catálogo de productos</a>
                </div>
            </div>
            <div class="col-md-4 text-center mt-4 mt-md-0">
                <div class="display-1">🧁</div>
            </div>
        </div>
    </section>

    {# Sección de Características / Accesos rápidos #}
    <section class="row g-3">
        <div class="col-md-3">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title text-danger">Catálogo</h5>
                    <p class="card-text text-muted">Productos con precio, stock e imagen actualizados en tiempo real.</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title text-danger">Recetas</h5>
                    <p class="card-text text-muted">Gestión de recetas: ingredientes detallados, pasos de elaboración y tiempos de horneado.</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title text-danger">Quedadas</h5>
                    <p class="card-text text-muted">Organiza las quedadas programadas para compartir tus tartas.</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title text-danger">Usuarios</h5>
                    <p class="card-text text-muted">Acceso seguro y gestión de perfiles mediante roles de usuario.</p>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
