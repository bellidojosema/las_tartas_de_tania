{% extends 'base.html.twig' %}

{% block title %}Quedadas{% endblock %}

{% block body %}
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Listado de Quedadas</h1>
            {# Solo el admin ve el botón de crear #}
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_pickup_appointment_new') }}" class="btn btn-primary-tania">Organizar Quedada</a>
            {% endif %}
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>¿Cuándo?</th>
                    <th>Organizado por</th>
                    <th>Estado</th>
                    <th>Notas</th>
                    {% if is_granted('ROLE_ADMIN') %}
                        <th class="text-center">Acciones</th>
                    {% endif %}
                </tr>
                </thead>
                <tbody>
                {% for appointment in appointments %}
                    <tr>
                        <td>{{ appointment.id }}</td>
                        {# CORRECCIÓN: Usamos pickupAt en lugar de scheduledAt #}
                        <td class="fw-bold">{{ appointment.pickupAt ? appointment.pickupAt|date('d/m/Y H:i') : 'Por confirmar' }}</td>

                        {# Mostramos quién organiza la quedada #}
                        <td>{{ appointment.user.userIdentifier }}</td>

                        <td>
                            {% if appointment.status == 'programada' %}
                                <span class="badge bg-info text-dark">Programada</span>
                            {% elseif appointment.status == 'realizada' %}
                                <span class="badge bg-success">Realizada</span>
                            {% elseif appointment.status == 'cancelada' %}
                                <span class="badge bg-danger">Cancelada</span>
                            {% else %}
                                <span class="badge bg-secondary">{{ appointment.status }}</span>
                            {% endif %}
                        </td>

                        <td class="small text-muted">{{ appointment.notes|default('Sin detalles') }}</td>

                        {% if is_granted('ROLE_ADMIN') %}
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <a href="{{ path('app_pickup_appointment_edit', {'id': appointment.id}) }}" class="btn btn-sm btn-outline-primary">Editar</a>

                                    <form method="post" action="{{ path('app_pickup_appointment_delete', {'id': appointment.id}) }}" onsubmit="return confirm('¿Seguro que quieres borrar esta quedada?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ appointment.id) }}">
                                        <button class="btn btn-sm btn-outline-danger">Eliminar</button>
                                    </form>
                                </div>
                            </td>
                        {% endif %}
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="{{ is_granted('ROLE_ADMIN') ? 6 : 5 }}" class="text-center text-muted py-5">
                            <p class="mb-0">No hay quedadas programadas. ¡Tania, organiza una!</p>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
