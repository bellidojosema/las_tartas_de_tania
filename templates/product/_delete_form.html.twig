<form method="post" action="{{ path('app_product_delete', {'id': product.id}) }}" onsubmit="return confirm('¿Estás seguro de eliminar esta tarta?');" style="display:inline-block">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
    <button class="btn btn-danger btn-sm" style="border-top-left-radius: 0; border-bottom-left-radius: 0;">
        Delete
    </button>
</form>
