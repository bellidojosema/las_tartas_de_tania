{% extends 'base.html.twig' %}

{% block title %}Editar producto | Las Tartas de Tania{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-md-8">
            {# Cabecera simple #}
            <div class="d-flex align-items-center mb-4">

                <div>
                    <h1 class="h3 mb-0 fw-bold text-danger">Editar producto</h1>
                    <p class="text-muted mb-0">Modifica la información del catálogo</p>
                </div>
            </div>

            {# Tarjeta del formulario #}
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-body p-4">
                    {{ include('product/_form.html.twig', {
                        form: form,
                        button_label: 'Actualizar producto'
                    }) }}

                    <hr class="my-4 text-muted opacity-25">

                    <div class="text-center">
                        <a class="btn btn-link text-secondary text-decoration-none" href="{{ path('app_product_index') }}">
                            ← Volver al listado sin guardar
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
