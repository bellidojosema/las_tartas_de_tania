{% extends 'base.html.twig' %}

{% block title %}Productos{% endblock %}

{% block body %}
    {# Contenedor fluido para aprovechar todo el ancho de la pantalla #}
    <div class="container-fluid px-4 mt-4">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0">Gestión de productos</h1>
            <a class="btn btn-primary shadow-sm" href="{{ path('app_product_new') }}">
                + Nuevo producto
            </a>
        </div>

        <div class="card shadow-sm border-0">
            <div class="table-responsive">
                {# La clase w-100 asegura el 100% del ancho #}
                <table class="table table-hover align-middle mb-0 w-100">
                    <thead class="table-light">
                    <tr>
                        <th style="min-width: 200px;">Nombre</th>
                        <th>Categoría</th>
                        <th>Precio</th>
                        <th>Stock</th>
                        <th class="text-center">Disponible</th>
                        <th class="text-end" style="min-width: 180px;">Acciones</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for product in products %}
                        <tr>
                            <td class="fw-bold text-primary">{{ product.name }}</td>
                            <td><span class="badge rounded-pill bg-light text-dark border">{{ product.category }}</span></td>
                            <td>{{ product.price|number_format(2, ',', '.') }} €</td>
                            <td>{{ product.stock }} unidades</td>
                            <td class="text-center">
                                {% if product.isAvailable %}
                                    <span class="text-success">● Disponible</span>
                                {% else %}
                                    <span class="text-danger">○ No disponible</span>
                                {% endif %}
                            </td>
                            <td>
                                <div class="d-flex justify-content-end gap-2">
                                    <a class="btn btn-sm btn-outline-primary" href="{{ path('app_product_edit', {id: product.id}) }}">
                                        Editar
                                    </a>
                                    <form method="post" action="{{ path('app_product_delete', {id: product.id}) }}" onsubmit="return confirm('¿Eliminar producto?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_product_' ~ product.id) }}">
                                        <button class="btn btn-sm btn-outline-danger">Eliminar</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="text-center py-5">
                                <p class="text-muted">No hay productos en la base de datos.</p>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
