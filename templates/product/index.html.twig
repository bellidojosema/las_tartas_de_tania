{% extends 'base.html.twig' %}

{% block title %}Productos{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0">Gestión de productos</h1>
        <a class="btn btn-danger" href="{{ path('app_product_new') }}">Nuevo producto</a>
    </div>

    <div class="table-responsive bg-white border rounded shadow-sm">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Nombre</th>
                    <th>Categoría</th>
                    <th>Precio</th>
                    <th>Stock</th>
                    <th>Disponible</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
            {% for product in products %}
                <tr>
                    <td>{{ product.name }}</td>
                    <td>{{ product.category }}</td>
                    <td>{{ product.price|number_format(2, ',', '.') }} €</td>
                    <td>{{ product.stock }}</td>
                    <td>{{ product.isAvailable ? 'Sí' : 'No' }}</td>
                    <td class="d-flex gap-1">
                        <a class="btn btn-sm btn-outline-secondary" href="{{ path('app_product_edit', {id: product.id}) }}">Editar</a>
                        <form method="post" action="{{ path('app_product_delete', {id: product.id}) }}" onsubmit="return confirm('¿Eliminar este producto?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_product_' ~ product.id) }}">
                            <button class="btn btn-sm btn-outline-danger">Eliminar</button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="6" class="text-center py-4">No hay productos creados todavía.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
