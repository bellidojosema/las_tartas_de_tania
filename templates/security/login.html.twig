{% extends 'base.html.twig' %}

{% block title %}Iniciar sesión | Las Tartas de Tania{% endblock %}

{% block body %}
    <div class="row justify-content-center mt-5">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <span class="display-4">🍰</span>
                        <h1 class="h3 mt-2 fw-bold text-danger">Acceso a la aplicación</h1>
                        <p class="text-muted">Introduce tus credenciales para continuar</p>
                    </div>

                    {# Gestión de errores de seguridad de Symfony #}
                    {% if error %}
                        <div class="alert alert-danger d-flex align-items-center" role="alert">
                            <svg class="bi flex-shrink-0 me-2" width="24" height="24" role="img" aria-label="Danger:"><use xlink:href="#exclamation-triangle-fill"/></svg>
                            <div>
                                {{ error.messageKey|trans(error.messageData, 'security') }}
                            </div>
                        </div>
                    {% endif %}

                    <form method="post">
                        <div class="mb-3">
                            <label class="form-label fw-semibold" for="username">Correo electrónico</label>
                            <input class="form-control form-control-lg" type="email" id="username" name="_username" value="{{ last_username }}" placeholder="nombre@ejemplo.com" required autofocus>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold" for="password">Contraseña</label>
                            <input class="form-control form-control-lg" type="password" id="password" name="_password" placeholder="••••••••" required>
                        </div>

                        {# Campo oculto para evitar ataques CSRF (Imprescindible en Symfony) #}
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                        <div class="d-grid gap-3">
                            <button class="btn btn-danger btn-lg shadow-sm" type="submit">
                                Entrar
                            </button>
                            <div class="text-center">
                                <span class="text-muted">¿Aún no tienes cuenta?</span>
                                <a class="text-danger fw-bold text-decoration-none" href="{{ path('app_register') }}">Registrarte</a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <div class="text-center mt-4">
                <a href="{{ path('app_home') }}" class="text-secondary text-decoration-none small">
                    ← Volver al inicio
                </a>
            </div>
        </div>
    </div>
{% endblock %}
