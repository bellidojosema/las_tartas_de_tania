{% extends 'base.html.twig' %}

{% block title %}Registro | Las Tartas de Tania{% endblock %}

{% block body %}
    {# Sección estilo Inicio (Hero) #}
    <section class="p-4 p-md-5 mb-4 bg-white rounded-3 shadow-sm border">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1 class="display-6 fw-bold text-danger">Crear cuenta</h1>
                <p class="lead mb-4">Únete a nuestra comunidad para gestionar tus tartas y galletas personalizadas de forma sencilla.</p>

                {{ form_start(registrationForm) }}
                <div class="row">
                    <div class="col-md-12 mb-3">
                        {{ form_row(registrationForm.fullName, {'label': 'Nombre completo'}) }}
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        {{ form_row(registrationForm.email, {'label': 'Correo electrónico'}) }}
                    </div>
                    <div class="col-md-6 mb-3">
                        {{ form_row(registrationForm.phone, {'label': 'Teléfono'}) }}
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6 mb-3">
                        {{ form_row(registrationForm.plainPassword.first, {'label': 'Contraseña'}) }}
                    </div>
                    <div class="col-md-6 mb-3">
                        {{ form_row(registrationForm.plainPassword.second, {'label': 'Repite contraseña'}) }}
                    </div>
                </div>

                <div class="d-flex flex-wrap gap-2">
                    <button type="submit" class="btn btn-danger px-4 shadow-sm">
                        Registrarme ahora
                    </button>
                    <a class="btn btn-outline-danger px-4" href="{{ path('app_login') }}">Ya tengo cuenta</a>
                    <a class="btn btn-dark px-4" href="{{ path('app_home') }}">Cancelar</a>
                </div>
                {{ form_end(registrationForm) }}
            </div>

            <div class="col-md-4 text-center mt-4 mt-md-0 d-none d-md-block">
                <div class="display-1">🍰</div>
                <p class="text-muted mt-2 fw-bold">Las Tartas de Tania</p>
            </div>
        </div>
    </section>

    {# Sección inferior informativa estilo Inicio #}
    <section class="row g-3">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body">
                    <h5 class="text-danger">Seguridad</h5>
                    <p class="mb-0 text-muted small">Tus datos están protegidos y solo se usan para la gestión de tus pedidos.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body">
                    <h5 class="text-danger">Rapidez</h5>
                    <p class="mb-0 text-muted small">Accede al catálogo y realiza tus encargos en menos de 2 minutos.</p>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
